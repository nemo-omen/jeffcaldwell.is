---
import '../style/global.css';
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
export interface Props {
	title: string;
}

const { title } = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="en">
<BaseHead {title} />

<body>
  <Header />
  <main>
	  <slot />
  </main>
  <Footer />
</body>
</html>