---
import Main from '../layouts/Main.astro';
import PostListItem from '../components/PostListItem.astro';
import PostFeature from '../components/PostFeature.astro';
const posts = await Astro.glob('./writing/*/*.md');
const sorted = await posts.sort((a,b) => {
  return new Date(a.date) - new Date(b.date)
});


console.log(sorted);
---
<Main title="trainingmontage">
  <PostFeature post={sorted[0]} />

<a href="/writing" class="heading-link">
  <h2 class="page-heading" id="latest">More Posts</h2>
</a>
<div class="post-grid">
  {sorted.slice(1, sorted.length).map((post) => (
    <PostListItem {post} />
  ))}
</div>
</Main>