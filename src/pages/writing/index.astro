---
import Main from '../../layouts/Main.astro';
import PostListItem from '../../components/PostListItem.astro';
import PostFeature from '../../components/PostFeature.astro';
const posts = await Astro.glob('./*/*.md');
const sorted = posts.filter((post) => post.frontmatter.draft === false).sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Main title={"Writing — Jeff Caldwell"}>
  <h2 class="page-heading" id="writing">Writing</h2>
  {sorted.length > 0 ?
  <div class="post-grid">
    {sorted.map((post) => (
    <PostFeature {post} />
    ))}
  </div>
  : <p>Okay, so I haven't written any blog posts yet.</p>
  <p>I promise I'm working on it!</p>
  <p>Meanwhile, <a href="/notes">check out my notes</a>!</p>
  }
</Main>