---
  import '../style/global.css';
  import JsonLD from '../components/JsonLD.astro';
  import BaseHead from './BaseHead.astro';
  import TwitterMeta from './TwitterMeta.astro';
  import OGMeta from './OGMeta.astro';
  import Header from '../components/Header.astro';
  import Footer from '../components/Footer.astro';
  const {content} = Astro.props;
  const author = 'Jeff Caldwell';
---
<!DOCTYPE html>
<html lang="en">
<BaseHead {content.title}>
  <OGMeta
    title={content.title}
    description={content.description}
    type="article"
    image={content.featuredImage ? 'https://jeffcaldwell.is' + content.featuredImage : 'https://jeffcaldwell.is/images/garden.png'}
  />
  <TwitterMeta
    title={content.title}
    description={content.description}
    image={content.featuredImage ? 'https://jeffcaldwell.is' + content.featuredImage : 'https://jeffcaldwell.is/images/garden.png'}
  />

  <JsonLD {content} />

</BaseHead>

<body>
  <Header />
  <main>
	  <article class="h-entry blog-content">
    {
      content.featuredImage 
      ? `<img src=${content.featuredImage} width="1000" height="500 class="featured-post-photo"/>`
      : ''
    }
    <h2 class="p-name page-heading">{content.title}</h2>
    <p>
      <time class="dt-published">{new Date(content.published).toLocaleDateString('en-US', {month: 'long', weekday: 'long', day: 'numeric', year: 'numeric'})}</time>
      , by 
      <a rel="author" class="p-author h-card" href="https://jeffcaldwell.is/about">{author}</a>,
      Last updated: 
      <time class="dt-published">{new Date(content.updated).toLocaleDateString('en-US', {month: 'long', weekday: 'long', day: 'numeric', year: 'numeric'})}</time>
    </p>
    <div class="e-content flow">
      <slot />
    </div>
  </article>
  </main>
  <Footer />
</body>
</html>