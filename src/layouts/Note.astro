---
  import '../style/global.css';
  import JsonLD from '../components/JsonLD.astro';
  import BaseHead from './BaseHead.astro';
  import TwitterMeta from './TwitterMeta.astro';
  import OGMeta from './OGMeta.astro';
  import Header from '../components/Header.astro';
  import Footer from '../components/Footer.astro';

  const { content } = Astro.props;
  const author = 'Jeff Caldwell';

  const allNotes = import.meta.glob('../pages/notes/**/*.md');

  let notes = await Promise.all(
    Object.entries(allNotes).map(async ([key, note]) => {
      const url = key.replace('../pages/notes/', '/notes/').replace('/index', '').replace('.md', '/');
      return note().then(async content => {
        const source = await content.default();
        return {
          ...source.frontmatter,
          url
        }
      })
    })
  );

  notes = notes.filter(note => {
    return note.astro.source.toLowerCase().includes(`[${content.title.toLowerCase()}]`);
  });
---

<!DOCTYPE html>
<html lang="en">
<BaseHead {content.title}>
  <OGMeta title={content.title} description={content.description} type="article" image={featuredImage} />
  <TwitterMeta title={content.title} description={content.description} image={featuredImage} />

  <JsonLD {content} />

</BaseHead>

<body>
  <Header />
  <main>
    <article class="h-entry blog-content">
      <h2 class="p-name page-heading">{content.title}</h2>
      <p>
        <time class="dt-published">{new Date(content.date).toLocaleDateString('en-US', {month: 'long', weekday: 'long',
          day: 'numeric', year: 'numeric'})}</time>
        , by
        <a rel="author" class="p-author h-card" href="https://jeffcaldwell.is/about">{author}</a>,
        Last updated:
        <time class="dt-published">{new Date(content.updated).toLocaleDateString('en-US', {month: 'long', weekday:
          'long', day: 'numeric', year: 'numeric'})}</time>
      </p>
      <div class="e-content flow">
        <slot />
      </div>
      { !notes.length ? null : <div>
        <h2>Backlinks</h2>
        <ul>
          {notes.map(note => {
          return <li class="mb-2">
            <a href={`${note.url}`}>{note.title}</a>
          </li>
          })}
        </ul>
      </div>
      }
    </article>
  </main>
  <Footer />
</body>

</html>